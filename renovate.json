{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "Europe/London",
  "schedule": ["before 6am on monday"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "labels": ["dependencies"],
  "automerge": false,
  "packageRules": [
    {
      "description": "Group all non-major updates into one PR",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch"
    },
    {
      "description": "Require manual dashboard approval for major updates",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Pin HA base image digests",
      "matchDatasources": ["docker"],
      "matchPackagePatterns": ["ghcr.io/home-assistant/.*"],
      "versioning": "docker",
      "pinDigests": true
    }
  ],
  "dockerfile": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  },
  "pip_requirements": {
    "enabled": true
  }
}